# ══════════════════════════════════════════════════════════════
# FireGuard XR — Environment Variables
# Copy this file to backend/.env and fill in your API keys
# ══════════════════════════════════════════════════════════════

# Google Gemini API — AI reasoning and wildfire analysis
GEMINI_API_KEY=

# ElevenLabs — Voice alert generation
ELEVENLABS_API_KEY=

# Cloudinary — Satellite image storage and analysis
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Maps API (optional — system uses OpenStreetMap by default)
GOOGLE_MAPS_API_KEY=

# NewsAPI — Wildfire news feed (optional — GDELT is used as free default)
# Get a free key at https://newsapi.org/register
NEWS_API_KEY=
